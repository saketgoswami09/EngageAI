# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Free tier: MongoDB Atlas (https://cloud.mongodb.com)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/whatsapp-ai?retryWrites=true&w=majority

# ─── Redis ────────────────────────────────────────────────────────────────────
# Free tier: Upstash Redis (https://upstash.com) — rediss:// for TLS
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "require('crypto').randomBytes(64).toString('hex')|clip"
JWT_ACCESS_SECRET=change_this_to_a_64_char_random_hex_string_access
JWT_REFRESH_SECRET=change_this_to_a_64_char_random_hex_string_refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── WhatsApp Business Cloud API ──────────────────────────────────────────────
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_BUSINESS_ACCOUNT_ID=1234567890
WHATSAPP_ACCESS_TOKEN=EAAxxxxxx...
WHATSAPP_WEBHOOK_VERIFY_TOKEN=my_custom_verify_token_123
WHATSAPP_APP_SECRET=your_meta_app_secret

# ─── AI (Free Tier Options) ───────────────────────────────────────────────────
# Option A — Groq (Recommended, generous free tier):
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
AI_MODEL=llama3-8b-8192

# Option B — Together AI:
# AI_BASE_URL=https://api.together.xyz/v1
# AI_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# Option C — OpenAI (paid):
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-3.5-turbo

# ─── Cost Control ─────────────────────────────────────────────────────────────
AI_DAILY_TOKEN_BUDGET=50000         # Total tokens per day across all users
AI_MAX_CALLS_PER_USER_PER_HOUR=10  # Per-user AI call rate limit

# ─── Cloud Storage ─────────────────────────────────────────────────────────────
# Free tier: Cloudinary (https://cloudinary.com) — 25 GB storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in MS
RATE_LIMIT_MAX=200             # Requests per window per IP
